                        "description": "Отсутствует файл или неверный запрос",
                        "schema": {
                            "$ref": "#/definitions/restapi.ErrorResp"
                        }
                    },
                    "401": {
                        "description": "Требуется аутентификация",
                        "schema": {
                            "$ref": "#/definitions/restapi.ErrorResp"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка",
                        "schema": {
                            "$ref": "#/definitions/restapi.ErrorResp"
                        }
                    }
                }
            }
        },
        "/api/v1/images/{id}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Возвращает метаданные изображения и массив привязанных тегов.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "images"
                ],
                "summary": "Получить информацию об изображении",
                "parameters": [
                    {
                        "type": "string",
