                            "$ref": "#/definitions/restapi.ErrorResp"
                        }
                    },
                    "409": {
                        "description": "Конфликт (тег с таким путём уже существует или попытка создать цикл)",
                        "schema": {
                            "$ref": "#/definitions/restapi.ErrorResp"
                        }
                    }
                }
            },
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
